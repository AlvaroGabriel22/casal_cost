DATABASE_URL="postgresql://user:password@localhost:5434/couple_finance_db?schema=public"
# When using a pooled connection (e.g. Neon/PgBouncer), set DATABASE_URL_UNPOOLED to a
# direct (non-pooled) connection used by Prisma for migrations. For local dev, you can
# point both to the same URL.
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5434/couple_finance_db?schema=public"

JWT_SECRET="change-me-in-production-use-long-random-string"

# Password reset e-mails (Resend — https://resend.com)
# Em dev, sem RESEND_API_KEY o link de reset aparece nos logs do backend.
RESEND_API_KEY=""
MAIL_FROM="CasalCost <onboarding@resend.dev>"
APP_URL="http://localhost:5173"
